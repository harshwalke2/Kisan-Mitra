    "lint": "eslint src/**/*.ts api/**/*.ts controllers/**/*.ts models/**/*.ts utils/**/*.ts",
    "db:migrate": "knex migrate:latest",
    "db:seed": "knex seed:run"
  },
  "dependencies": {
