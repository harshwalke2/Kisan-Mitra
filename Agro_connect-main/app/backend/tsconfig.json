{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "api/**/*.ts",
    "controllers/**/*.ts",
    "models/**/*.ts",
    "utils/**/*.ts",
    "config/**/*.ts",
    "middleware/**/*.ts",
    "services/**/*.ts",
    "socket/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}