# Server
NODE_ENV=development
PORT=5055

# Frontend URLs (comma-separated if multiple)
FRONTEND_URL=http://localhost:5188
FRONTEND_URLS=http://localhost:5188,http://localhost:5173
FRONTEND_RESET_URL=http://localhost:5188
# In production, set to your exact deployed app URL(s), e.g. https://kisan-mitra1.netlify.app
# Optional: allow any *.netlify.app and *.onrender.com preview origins
ALLOW_PREVIEW_ORIGINS=false
# Emergency toggle for cross-origin issues in hosted demos (set false for stricter policy)
CORS_ALLOW_ALL=false

# Auth endpoint rate limits (per IP)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_MAX_ATTEMPTS=10
AUTH_REGISTER_MAX_ATTEMPTS=10
AUTH_FORGOT_PASSWORD_MAX_ATTEMPTS=5
AUTH_RESET_PASSWORD_MAX_ATTEMPTS=20

# Database
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster-host>/agroconnect_chat?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_long_random_secret

# Python runner for crop recommendation
PYTHON_EXECUTABLE=python3
# Optional: external FastAPI crop recommendation service URL (e.g. https://your-crop-api.onrender.com)
CROP_RECO_API_URL=

# WhatsApp chatbot (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_BOT_DEFAULT_LANG=en

# Disease detection model API (Flask/FastAPI)
DISEASE_ML_API_URL=http://localhost:5000/predict

# Email (optional in dev, required for production reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AgroConnect <no-reply@agroconnect.local>

# Optional: comma-separated emails treated as admin (in addition to role=admin)
ADMIN_EMAILS=

# Live market insights via https://data.gov.in (optional). If missing, backend falls back to local mandi CSV.
DATA_GOV_API_KEY=
DATA_GOV_RESOURCE_ID=
DATA_GOV_BASE_URL=https://api.data.gov.in/resource
DATA_GOV_LOCAL_CSV_PATH=

# Smart notification system
OPENWEATHER_API_KEY=
NOTIFICATION_CRON_SCHEDULE=0 */4 * * *
NOTIFICATION_RUN_ON_START=true

# Government scheme auto-sync
# Modes: json_url | data_gov
SCHEME_SYNC_MODE=json_url
# Required when mode=json_url (endpoint returning JSON array or { schemes: [] } or local JSON file path)
SCHEME_SYNC_SOURCE_URL=./data/government_schemes_feed.json
SCHEME_SYNC_CRON_SCHEDULE=0 */12 * * *
SCHEME_SYNC_RUN_ON_START=true

# Data.gov adapter (used when mode=data_gov)
# API key/resource id can also reuse DATA_GOV_API_KEY / DATA_GOV_RESOURCE_ID values.
SCHEME_SYNC_DATA_GOV_API_KEY=
SCHEME_SYNC_DATA_GOV_RESOURCE_ID=
SCHEME_SYNC_DATA_GOV_BASE_URL=https://api.data.gov.in/resource
SCHEME_SYNC_DATA_GOV_LIMIT=1000
